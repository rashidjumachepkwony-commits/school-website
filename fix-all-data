                attendance: attendance,
                createdAt: new Date(),
                updatedAt: new Date()
            };
            
            await db.collection('teachers').insertOne(teacher);
            imported++;
            console.log(`  ✅ ${data.firstName} ${data.lastName} (${data.employeeId})`);
            console.log(`     CheckIn: ${data.checkInTime} → ${checkInDate}`);
