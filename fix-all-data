        console.log(`✅ Imported ${imported} teachers\n`);
        
        // ============================================
        // 3. FIX TIMES (ADD 3 HOURS FOR KENYA TIME)
        // ============================================
        console.log('🔧 Fixing times (Kenya time UTC+3)...\n');
        
        const teachers = await db.collection('teachers').find({}).toArray();
        let fixed = 0;
        let recordCount = 0;
        
        for (const teacher of teachers) {
            let changed = false;
            console.log(`📝 ${teacher.firstName} ${teacher.lastName}`);
            
            for (const record of teacher.attendance || []) {
                // Fix checkIn - add 3 hours
                if (record.checkIn) {
                    const original = new Date(record.checkIn);
                    const kenyaTime = new Date(original.getTime() + (3 * 60 * 60 * 1000));
                    record.checkIn = kenyaTime;
                    changed = true;
                    recordCount++;
                    console.log(`  ✅ CheckIn: ${original.toLocaleTimeString()} → ${kenyaTime.toLocaleTimeString()}`);
                }
                
                // Fix checkOut - add 3 hours
                if (record.checkOut) {
                    const original = new Date(record.checkOut);
                    const kenyaTime = new Date(original.getTime() + (3 * 60 * 60 * 1000));
                    record.checkOut = kenyaTime;
                    changed = true;
                    recordCount++;
                    console.log(`  ✅ CheckOut: ${original.toLocaleTimeString()} → ${kenyaTime.toLocaleTimeString()}`);
                }
                
                // Fix date field
                if (record.date) {
                    const original = new Date(record.date);
                    const kenyaTime = new Date(original.getTime() + (3 * 60 * 60 * 1000));
                    record.date = kenyaTime;
                    changed = true;
                }
                
                // Recalculate hours
                if (record.checkIn && record.checkOut) {
                    const checkIn = new Date(record.checkIn);
                    const checkOut = new Date(record.checkOut);
                    const hours = ((checkOut - checkIn) / (1000 * 60 * 60)).toFixed(2);
                    record.hoursWorked = parseFloat(hours);
                    changed = true;
                    console.log(`  ✅ Hours: ${hours} hrs`);
                }
            }
            
            if (changed) {
                await db.collection('teachers').updateOne(
                    { _id: teacher._id },
                    { $set: { attendance: teacher.attendance } }
                );
                fixed++;
                console.log(`  ✅ ${teacher.firstName} ${teacher.lastName} FIXED\n`);
            } else {
                console.log(`  ⏭️ No changes needed\n`);
            }
        }
        
